#!/bin/bash
#PBS -q {{GPU_QUEUE}}
#PBS -P {{NCI_PROJECT}}
#PBS -l ngpus=4
#PBS -l ncpus=48
#PBS -l mem=380GB
#PBS -l walltime=04:00:00
#PBS -l jobfs=200GB
#PBS -l storage=scratch/{{NCI_PROJECT}}
#PBS -N llm-discovery
#PBS -o llm-discovery.out
#PBS -e llm-discovery.err

# Load required modules
module load cuda/12.9.0
module load singularity

# Paths
REMOTE_BASE="/scratch/{{NCI_PROJECT}}/llm-discovery"
DATA_DIR="${REMOTE_BASE}/data"
HF_CACHE="/scratch/{{NCI_PROJECT}}/hf_cache"
CONTAINER_PATH="{{CONTAINER_PATH}}"

# Redirect caches to current job's jobfs to avoid stale paths from
# previous jobs (PermissionError on /jobfs/<old-job-id>/).
# VLLM_CACHE_ROOT: vLLM's compile cache (default ~/.cache/vllm/)
# TORCHINDUCTOR_CACHE_DIR: torch inductor cache (default /tmp/torchinductor_*)
export VLLM_CACHE_ROOT="${PBS_JOBFS}/vllm_cache"
export TORCHINDUCTOR_CACHE_DIR="${PBS_JOBFS}/torchinductor"

cd "${REMOTE_BASE}" || exit 1

# Run pipeline inside container
# Gadi auto-mounts /scratch, /jobfs, home dirs, and NVIDIA drivers.
# --bind mounts data directory and HuggingFace model cache.
# The container entrypoint sources /data/hpc_env.sh for GPU-specific config.
# NOTE: For TP>1, if shared memory errors occur, add --writable-tmpfs flag.
singularity exec --nv \
    --bind "${DATA_DIR}:/data" \
    --bind "${HF_CACHE}:/model_cache" \
    --env HF_HOME=/model_cache \
    --env VLLM_CACHE_ROOT="${VLLM_CACHE_ROOT}" \
    --env TORCHINDUCTOR_CACHE_DIR="${TORCHINDUCTOR_CACHE_DIR}" \
    "${CONTAINER_PATH}" \
    /opt/llm-discovery/container/entrypoint.sh
